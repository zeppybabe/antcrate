# Runtime artifacts (none should normally land in this tree, but be defensive)
*.log
*.swp
*~
.DS_Store

# Editor / IDE
.vscode/
.idea/

# Local-only env / secrets — must never be committed
.env
.env.*
*.pem
*.key

# Python / Node noise that could appear if anyone runs tools in the tree
__pycache__/
node_modules/
.pytest_cache/

# AntCrate per-project runtime state (cody-attempts.json + future counters).
# This skill is registered as a self-project, so the lifecycle treatment
# (#92) drops .antcrate/ here. Counter file churns on every delegation —
# never useful to track.
.antcrate/

# C++ build artifacts (Wave 0+; antcrate-core out-of-source CMake build).
# Keep src/, include/, tests/, CMakeLists.txt tracked; ignore generated.
assets/code/core/build/

# Claude Code background-session worktrees (scratch isolation)
.claude/worktrees/
.env.local
.env.*.local

# dev-internal records — local to maintainers, never pushed to the public repo
dev/
# antcrate's lifecycle/md-scaffold regenerates these record skeletons at the
# project root; anchor-ignore them so a regenerated stub can never reach the
# public repo. The real records live under dev/. stack.md stays public.
/ledger.md
/state.md
/state-archive.md
/duties.md
/composes.md
