#!/usr/bin/env bash
# antcrate-template: pre-commit-secrets
# antcrate-template-version: 1.0
# Project: __PROJECT_NAME__
#
# Refuses commits that include secret-pattern files. Mirrors the secret
# guard in antcrate's lib/commit.sh so projects that don't use --commit
# (or that get bypassed) still have a backstop.
#
# Patterns: .env, .env.*, *.pem, *.key, id_rsa/dsa/ed25519/ecdsa,
#           *.p12, *.pfx, secrets.yml, secrets.yaml, *.credentials,
#           credentials.json, .netrc

set -euo pipefail

LOG=".git/antcrate-hook.log"
TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)

is_secret() {
    case "$1" in
        .env|.env.*) return 0 ;;
        *.pem|*.key) return 0 ;;
        id_rsa|id_dsa|id_ed25519|id_ecdsa) return 0 ;;
        *.p12|*.pfx) return 0 ;;
        secrets.yml|secrets.yaml) return 0 ;;
        *.credentials|credentials.json) return 0 ;;
        .netrc) return 0 ;;
    esac
    return 1
}

matched=()
while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    base=$(basename "$f")
    if is_secret "$base"; then matched+=("$f"); fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if (( ${#matched[@]} > 0 )); then
    {
        printf '%s [pre-commit-secrets] FAIL: secret-pattern file(s) staged:\n' "$TS"
        printf '  %s\n' "${matched[@]}"
        printf '%s [pre-commit-secrets] hint: unstage with `git restore --staged <file>`\n' "$TS"
        printf '%s [pre-commit-secrets] hint: add the basename to .gitignore so this does not recur\n' "$TS"
    } | tee -a "$LOG" >&2
    exit 1
fi

printf '%s [pre-commit-secrets] PASS\n' "$TS" >> "$LOG" 2>/dev/null || true
exit 0
