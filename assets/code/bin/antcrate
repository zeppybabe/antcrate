# ANTCRATE_HOME / ANTCRATE_ROOT and all other path vars are set by paths.sh
# (sourced first), which honors $XDG_*_HOME and defaults to ~/Projects.

usage_compact() {
    cat <<'USAGE'
antcrate — deterministic project ops (compact form; `antcrate help --all` = full flag reference)

Commands:
  st                      status dashboard (daemon, registry, duties, backups, ghosts)
  pp <p>                  pre-push panel (versions, milestone, diff, backup age), then commit+push
  info <p>                registry record + the same panel, read-only
  new <n> --domain <d>    full project bundle: scaffold + git init + md skeletons + agent pointer
  reg <n> <path>          register an existing tree
  commit <p> -m "…" [--all-tracked | -- <files…>]   guarded commit (secret-pattern scan, preview)
  bak <p> [ls|restore [--at <ts>]]                  backups
  duty [add ["-…"]|done N|clear|ls]                 human-action checklist (duties)
  hook <ls|log|install|rm|debug|smoke|render|bypass|audit|auto> <p>
  self <check|test|ci|src|edit|install>             antcrate itself
  tool <install|ls|path>                            pinned local dev tools (no root)
  gc <p> | gc ghosts                                cleanup candidates / ghost registry entries
  mv <old> <new> · arc [-u] <p> · rm <p>            rename / (un)archive / remove — all backed up
  in <p> -- <cmd> · map <p> · watch [<p>] · scan [path] · fetch <url>
  list · diff <p> · logs [p [n]] · propose <name> "<intent>"

Non-interactive by default: no -y, no PREAPPROVED env. Destructive ops back up
first and file a review duty (`antcrate duties`) when no human is present.
USAGE
}

usage() {
    cat <<'USAGE'
antcrate — pure-Bash deterministic project scaffolder

Compact form (audit 2026-07-10; --flags below remain valid one release):
  st · pp <p> · new <n> -d <dom> · reg <n> <path> · commit <p> -m "…"
  bak <p> [ls|restore] · duty [add|done N|clear|ls] · duties
  hook <sub> <p> · self <check|test|ci|src|edit|install> · tool <install|ls|path>
  gc <p>|ghosts · mv <old> <new> · arc [-u] <p> · rm <p>
  in <p> -- <cmd> · map · watch · scan · fetch · info · list · diff · logs · help
  All prompts are non-interactive-safe: no -y / PREAPPROVED needed; destructive
  ops back up first and file a review duty when no human is present.

Commands:
  --init                              first-run setup ($HOME/.antcrate, config)
  --start <n> --domain <d>         create new project; --meta "csv" or "k=v"
  --register <n> <existing-path> [--domain <d>]
                                      add a registry entry for an existing tree (no scaffold)
  --branch <n> --domain <d>        new project, optionally --meta "from=<base>"
  --link <a> --rel <b>                bidirectional link between two projects
  --commit <project> -m "<msg>" [--all-tracked | -- <files...>] [-y]
                                      stage + commit via the wrapper (secret-pattern guard,
                                      Gateway Law preview, y/N prompt). -y bypasses prompt
                                      (sanctioned for non-TTY automation). Replaces bare
                                      git add+commit.
  --pp <project> [-y]                 commit (if dirty) and push, with conflict triage
  --ingest <bundle-path>              consume a research bundle (BUNDLE_SPEC v1.0)
  --emit-activity <project> <kind> <relpath> [--ttl-ms N] [--label X] [--agent A]
                                      append an event to the activity stream
                                      kinds: modify | read | think | delegate | delete
  --watch [<project>] [--follow] [--once] [--interval-ms N] [--no-color] [--depth N]
                                      full-screen colored tree painted by active
                                      events (alt-screen, clamped to terminal);
                                      --follow tracks the most-active project
  --watch-smoke <project> [kind] [relpath] [--ttl-ms N] [--depth N] [--no-color]
                                      emit one event then render the tree once
                                      (smoke shortcut for emit-activity + watch --once)
                                      defaults: kind=modify, relpath=., ttl=60000ms
  --watch-window <project> [--terminal NAME]
                                      spawn a detached terminal window running
                                      --watch; dedup by PID file at
                                      ~/.antcrate/watch/<project>.pid.
                                      supported terminals: alacritty (default)
  --cleanup <project> [--apply <id>[,<id>...]]
                                      list test/cache/empty-dir candidates;
                                      --apply removes per id (rule #1 backup gate,
                                      emits 1s tombstone event per removal)
  --resume <parent> --expand <child>  atomic sub-branch / nesting refactor
  --gh-init <project> [--public]      create GitHub repo via HTTPS, push initial commit
  --gh-help                           show GitHub HTTPS onboarding steps
  --git-init <project>                local-only: idempotent git init + core.hooksPath wire
                                      (no remote; counterpart to --gh-init)
  --agent-init <project>              drop project-scoped Cody pointer at
                                      <project>/.claude/agents/<project>-cody.md
                                      and initialize the attempt counter at
                                      <project>/.antcrate/cody-attempts.json. Idempotent.
  --md-scaffold <project> [--force]   write CLAUDE.md / AGENTS.md / state.md / ledger.md
                                      at the project root from internal-md templates.
                                      Refresh-only by default; --force backs up existing
                                      files to <file>.bak.<ts> then overwrites.
  --profile <project> [--raw]         read-only stack/tooling/env profile + hook
                                      recommendations. --raw emits a TAB-separated
                                      stream for downstream consumption.
  --env-scan <project> [--apply]      list .env files + env-var references.
                                      --apply idempotently adds standard .env
                                      patterns to .gitignore (.env, .env.local,
                                      .env.*.local). Never modifies .env files.
  --hook-autoinstall <project> [--dry-run]
                                      one-shot: read --profile recommendations,
                                      install picked hook template per slot,
                                      patch .gitignore for env safety. Idempotent.
                                      --dry-run prints the plan only.
  --bootstrap <project> [-m "<msg>"] [--with-remote [--public|--private]]
                                      one-liner: --git-init + default .gitignore + first commit;
                                      --with-remote chains --gh-init (private default)
  --backup <project>                  create on-demand backup (tar.gz under ~/.antcrate/backups/)
  --backups <project>                 list backups for a project
  --restore <project> [--at <ts>]     restore project from backup (latest if --at omitted)
  --propose <name> "<description>"    log a proposed pattern (escape valve when no flag fits)
  --proposals                         list all logged pattern proposals
  --policy                            show the policy.json file (models/budgets/classes)
  --policy-init                       seed policy.json if absent (idempotent)
  --duty [--type <t>] "<text>"        append a human-only action to duties.md (checklist);
                                      types: policy|command|research|debug (untyped = policy)
  --duties                            numbered list of OPEN duties (typed tags shown)
  --duty-done <n>                     mark nth open duty done (user-driven)
  --duties-clear                      mark ALL open duties done at once (never deletes)
  --duty-involvement                  print effective duty_involvement (lean|standard|hands-on)
  --fetch <url> [--name <slug>]       no-LLM web fetch: normalize + snapshot to
                                      ~/.antcrate/fetch/<slug>/ (append-only, hash-keyed);
                                      research order: TH duty -> --fetch -> model LAST
  --addr <project> <code>             resolve a layered address (e.g. 1a3) to a path
  --anchor <project> [--addr <code>]  emit eval-able exports: ANTCRATE_ANCHOR=...
  --in <project> [--addr <code>] -- <cmd...>
                                      run <cmd> with cwd set to anchor (no shell pollution)
  --map <project>                     print addressed tree with dynamic/static tags
  --rename <project> <new-name>       backup-protected rename + registry rewrite
  --archive <project>                 backup-protected move to ~/projects/.archive/
  --unarchive <project>               restore an archived project to its previous parent
  --remove <project>                  PERMANENT delete (backup + approval; recovery via tarball only)
  --relocate <project> [--no-watch]   move a project out of ~/.claude into ~/projects (symlink left
                                      behind; --no-watch keeps the daemon off it)
  --logs [project] [lines]            tail wrapper/daemon/conflict logs (+git log if project)
  --diff <project>                    git status + diff via git -C (no cd)
  --selfsrc                           print the antcrate skill source root
  --tool-install <tool> [--force]     provision a pinned, sha256-verified dev tool
                                      locally (no root) under the XDG data dir;
                                      appends an auditable manifest line. The
                                      no-root, no-sudo alternative gated by the
                                      local-install guard hook. Tools: shellcheck, bats
  --tool-list                         list known tools and install status
  --tool-path                         print the local tools bin dir (add to PATH)
  --scan [path]                       leak scan (gitleaks secrets + dev-internal
                                      marker grep) over [path] (default: cwd);
                                      exit 1 on any finding. Powers the pre-push guard
  --selfinstall                       run install.sh from selfsrc
  --install-from-source               run install.sh from the registered 'antcrate'
                                      project path (bypasses ANTCRATE_SELFSRC cache)
  --selftest [pattern]                run bats tests/[pattern].bats from selfsrc
  --selfedit <relpath>                print absolute path to a file under selfsrc
  --diagrams <project>                render docs/diagrams/*.{mmd,puml,d2} to .svg if tools present
  --registry-diagram [out]            emit Mermaid graph of the entire registry
  --tree-diagram <project> [out]      emit Mermaid graph of project's addressed tree
  --ci [--snapshot] [--source <path>] run shellcheck + bats; nonzero on any
                                      failure. PASS updates ci-baseline.json .last;
                                      --snapshot also sets .baseline (audit cadence);
                                      --source CIs an alternate tree (e.g. a worktree)
  --hook-smoke <hook-script>          pipe a synthetic Claude Code hook payload into a hook
               (--command <cmd> | --file <path> | --payload <json>) [--tool <name>]
                                      and report exit + stderr (0 allow / 1 warn / 2 block;
                                      exit code propagates)
  --hooks <project>                   list active git hooks for a project (read-only)
  --hook-log <project> [lines]        tail .git/antcrate-hook.log for debugging blocked commits
  --hook-install <project> <template> [hook-name] [--force]
                                      install a hook template into the project (idempotent;
                                      backup-then-overwrite on --force). Templates ship at
                                      assets/code/hooks/templates/.
  --hook-remove <project> <hook> [--force]
                                      remove a hook (backs up to <hook>.bak.<ts>; audit-logged
                                      to ~/.antcrate/hooks.log + .git/antcrate-hook-audit.log).
  --hook-debug <project> [hook] [--with-stash] [--no-trace]
                                      re-run a hook with annotated trace + captured stdout/stderr;
                                      defaults to pre-commit; --with-stash mirrors the commit-time
                                      staged set; --no-trace skips bash -x. Audit-logged + appended
                                      to .git/antcrate-hook.log. Exits with the hook's exit code.
  --hook-bypass <project> --reason "<text>"
                                      write a single-shot bypass flag at .git/antcrate-hook-bypass;
                                      the next antcrate-shipped hook consumes it, logs the bypass +
                                      reason to .git/antcrate-hook.log + .git/antcrate-hook-audit.log,
                                      deletes the flag, exits 0. AGENTS.md rule #14: agents may
                                      PROPOSE this; humans run the command.
  --hook-render <template> [project]  render a hook template to stdout (no install). Substitutes
                                      __PROJECT_NAME__, __ANTCRATE_BIN__, and injects the
                                      __ANTCRATE_BYPASS_CHECK__ block. Useful for previewing a
                                      template after edits to catch injection bugs before install.
  --hook-audit <project> [N]          unified view of three hook audit sinks (global JSONL filtered
                                      to project, per-project plain, human-readable hook log). N
                                      caps lines per sink (default 20). Read-only.
  --quarantine-list <project>         list quarantine entries for a project (read-only, DESC by timestamp)
  --quarantine-restore <project> --at <ts>
                                      restore a quarantined entry to its original_path;
                                      REFUSES (exit 1) if original_path already exists.
                                      No --quarantine-purge: only the user manually deletes the quarantine root.
  --ghosts                            list all registry entries whose path no longer exists (read-only)
  --deregister <project>              drop a ghost entry from registry (capture-first; refuses if
                                      path exists — use --archive instead)
  --pipe-file <basename>              decode a Positional filename and dispatch
  --status                            show daemon + registry summary
  --selfcheck [--quiet]               self-source persistence health (path, skill link,
                                      git, unpushed, uncommitted, backup age);
                                      exit 0 ok / 1 critical / 2 warnings
  --intel-pull [--source <id>]        fetch pinned Anthropic-only sources; snapshot +
               [--quiet]              unread row on change (exit 2 on non-Anthropic host)
  --intel-new [--json]                unread intel items (new minus acked)
  --intel-ack <id> <sha256>           mark an intel item reviewed
  --intel-status                      per-source last-pull / last-change / unread
  --list                              list registered projects
  --info <project>                    formatted record: path, domain, git_remote,
                                      linked, backups, branch + last_commit + working state
  --help                              this message

Env:
  ANTCRATE_ROOT      project root (default: $HOME/projects)
  ANTCRATE_HOME      state dir   (default: $HOME/.antcrate)
  ANTCRATE_EMAIL     triage email recipient
  ANTCRATE_LOG_LEVEL debug|info|warn|error
USAGE
}

cmd_init() {
    mkdir -p "$ANTCRATE_CONFIG_HOME" "$ANTCRATE_DATA_HOME" "$ANTCRATE_STATE_HOME" \
             "$ANTCRATE_LOG_DIR" "$ANTCRATE_TEMPLATES"
    mkdir -p "$ANTCRATE_ROOT"
    ac_registry_init
    if [[ ! -f "$ANTCRATE_CONFIG" ]]; then
        if [[ -f "$ANTCRATE_TEMPLATES/config.example" ]]; then
            cp "$ANTCRATE_TEMPLATES/config.example" "$ANTCRATE_CONFIG"
        else
            cat > "$ANTCRATE_CONFIG" <<'EOF'
# antcrate user config — sourced by wrapper and daemon
# ANTCRATE_EMAIL="you@example.com"
# ANTCRATE_GIT_REMOTE_PREFIX="https://github.com/youruser/"
EOF
        fi
        ac_info "init: created $ANTCRATE_CONFIG (edit to set email + remote prefix)"
    fi
    ac_info "init: ready (root=$ANTCRATE_ROOT, config=$ANTCRATE_CONFIG, data=$ANTCRATE_DATA_HOME, state=$ANTCRATE_STATE_HOME)"
}

cmd_pipe_file() {
    local fname="$1"
    if ! ac_schema_decode "$fname"; then
        local rc=$?
        if (( rc == 2 )); then
            ac_warn "pipe-file: unknown action in '$fname'"
        else
            ac_debug "pipe-file: '$fname' did not match schema (skipped)"
        fi
        return 0
    fi
    ac_info "pipe-file: $(ac_schema_describe)"
    ac_with_lock ac_scaffold_dispatch
}

cmd_pp() {
    local project="$1" auto_yes="${2:-}"
    if ! ac_registry_has "$project"; then
        ac_error "pp: unknown project '$project'"; exit 1
    fi
    local p; p=$(ac_registry_get "$project" path)
    [[ -d "$p" ]] || { ac_error "pp: path missing: $p"; exit 1; }

    # the bundled panel: full situational read before any action (Plan 2)
    ac_pp_panel "$project" "$p"

    if [[ -n "$(git -C "$p" status --porcelain 2>/dev/null)" ]]; then
        if [[ "$auto_yes" != "-y" ]] \
           && ! ac_gate_confirm "Uncommitted changes in $project. Commit & push?"; then
            ac_warn "pp: aborted by user"; exit 0
        fi
        git -C "$p" add -A
        git -C "$p" commit -qm "antcrate: auto-commit $(date -u +%Y-%m-%dT%H:%M:%SZ)" || true
    fi
    ac_git_push "$project" "$p" || true
}

cmd_resume_expand() {
    local parent="$1" child="$2"
    ac_subbranch_expand "$parent" "$child"
}

cmd_status() {
    printf 'antcrate status\n'
    printf '  root      : %s\n' "$ANTCRATE_ROOT"
    printf '  home      : %s\n' "$ANTCRATE_HOME"
    printf '  registry  : %s\n' "$ANTCRATE_REGISTRY"
    if [[ -f "$ANTCRATE_HOME/daemon.pid" ]] \
       && kill -0 "$(cat "$ANTCRATE_HOME/daemon.pid")" 2>/dev/null; then
        printf '  daemon    : running (pid %s)\n' "$(cat "$ANTCRATE_HOME/daemon.pid")"
    else
        printf '  daemon    : not running\n'
    fi
    if ac_pipe_paused; then printf '  pipe      : PAUSED\n'; else printf '  pipe      : active\n'; fi
    local n; n=$(ac_registry_list | wc -l)
    printf '  projects  : %s registered\n' "$n"
    local sc_out sc_rc=0
    sc_out=$(ac_selfcheck --quiet 2>/dev/null) || sc_rc=$?
    if (( sc_rc == 1 )); then
        printf '  selfsrc   : %s — run --selfcheck\n' "${sc_out#selfcheck: }"
    else
        printf '  selfsrc   : %s\n' "${sc_out#selfcheck: }"
    fi
    local intel_out
    intel_out=$(ac_intel_status_line 2>/dev/null) || true
    [[ -n "$intel_out" ]] && printf '  %s\n' "${intel_out/: /     : }"
    local audit_out
    audit_out=$(ac_devops_audit_status_line 2>/dev/null) || true
    [[ -n "$audit_out" ]] && printf '  %s\n' "${audit_out/: /     : }"
    local duties_out
    duties_out=$(ac_duties_status_line 2>/dev/null) || true
    [[ -n "$duties_out" ]] && printf '  %s\n' "${duties_out/: /    : }"
    # ghost entries (registered path gone) — cheap registry walk (Plan 2)
    local ghosts=0 gp
    while IFS=$'\t' read -r _ gp; do
        [[ -d "$gp" ]] || ghosts=$((ghosts + 1))
    done < <(ac_registry_dump 2>/dev/null \
        | jq -r '.projects | to_entries[] | "\(.key)\t\(.value.path)"' 2>/dev/null)
    printf '  ghosts    : %s\n' "$ghosts"
    # backup posture: newest tarball anywhere (Plan 2)
    local newest_b
    newest_b=$(find "${ANTCRATE_BACKUP_DIR:-$ANTCRATE_HOME/backups}" -name '*.tar.gz' \
        -printf '%T@\t%p\n' 2>/dev/null | sort -rn | head -1 | cut -f2-) || newest_b=""
    if [[ -n "$newest_b" ]]; then
        printf '  backups   : newest %s (%s ago)\n' \
            "$(basename "$newest_b")" "$(_ac_pp_age "$(stat -c %Y "$newest_b")")"
    else
        printf '  backups   : none\n'
    fi
}

cmd_list() {
    ac_registry_dump | jq -r '
        .projects | to_entries | .[] |
        "\(.key)\t\(.value.path)\tparent=\(.value.parent)\tlinks=\(.value.linked_nodes | length)"
    '
}

# load user config if present
# shellcheck source=/dev/null
[[ -f "$ANTCRATE_CONFIG" ]] && . "$ANTCRATE_CONFIG"

# arg parsing
[[ $# -eq 0 ]] && { usage_compact; exit 0; }

# ── subcommand dispatcher (audit 2026-07-10) ────────────────────────────────
# Compact words rewrite argv into the canonical --flag form; the parser below
# is untouched. Legacy --flags remain valid one release, then retire.
if [[ "${1:0:1}" != "-" ]]; then
    _sub="$1"; shift
    case "$_sub" in
        help)   if [[ "${1:-}" == "--all" || "${1:-}" == "all" ]]; then usage; else usage_compact; fi
                exit 0 ;;
        st)     set -- --status "$@" ;;
        new)    set -- --start "$@" ;;
        reg)    set -- --register "$@" ;;
        mv)     set -- --rename "$@" ;;
        arc)    if [[ "${1:-}" == "-u" ]]; then shift; set -- --unarchive "$@"
                else set -- --archive "$@"; fi ;;
        rm)     set -- --remove "$@" ;;
        gc)     if [[ "${1:-}" == "ghosts" ]]; then shift; set -- --ghosts "$@"
                else set -- --cleanup "$@"; fi ;;
        bak)    case "${1:-}" in
                    ls)      shift; set -- --backups "$@" ;;
                    restore) shift; set -- --restore "$@" ;;
                    *)       set -- --backup "$@" ;;
                esac ;;
        duty)   case "${1:-}" in
                    ls|'')   [[ $# -gt 0 ]] && shift; set -- --duties "$@" ;;
                    done)    shift; set -- --duty-done "$@" ;;
                    clear)   shift; set -- --duties-clear "$@" ;;
                    add)     shift; set -- --duty "$@" ;;
                    *)       set -- --duty "$@" ;;
                esac ;;
        duties) set -- --duties "$@" ;;
        hook)   case "${1:-}" in
                    ls)      shift; set -- --hooks "$@" ;;
                    log)     shift; set -- --hook-log "$@" ;;
                    install) shift; set -- --hook-install "$@" ;;
                    rm)      shift; set -- --hook-remove "$@" ;;
                    debug)   shift; set -- --hook-debug "$@" ;;
                    smoke)   shift; set -- --hook-smoke "$@" ;;
                    render)  shift; set -- --hook-render "$@" ;;
                    bypass)  shift; set -- --hook-bypass "$@" ;;
                    audit)   shift; set -- --hook-audit "$@" ;;
                    auto)    shift; set -- --hook-autoinstall "$@" ;;
                    *)       ac_error "hook: unknown sub '${1:-}' (ls|log|install|rm|debug|smoke|render|bypass|audit|auto)"; exit 2 ;;
                esac ;;
        self)   case "${1:-}" in
                    check)   shift; set -- --selfcheck "$@" ;;
                    test)    shift; set -- --selftest "$@" ;;
                    ci)      shift; set -- --ci "$@" ;;
                    src)     shift; set -- --selfsrc "$@" ;;
                    edit)    shift; set -- --selfedit "$@" ;;
                    install) shift; set -- --selfinstall "$@" ;;
                    *)       ac_error "self: unknown sub '${1:-}' (check|test|ci|src|edit|install)"; exit 2 ;;
                esac ;;
        tool)   case "${1:-}" in
                    ls)      shift; set -- --tool-list "$@" ;;
                    path)    shift; set -- --tool-path "$@" ;;
                    install) shift; set -- --tool-install "$@" ;;
                    *)       set -- --tool-install "$@" ;;
                esac ;;
        pp|commit|watch|scan|fetch|map|anchor|in|info|list|status|start|branch|link|ingest|backup|backups|restore|propose|proposals|policy|diff|logs|ci|ghosts|deregister|cleanup|relocate|archive|unarchive|remove|rename|bootstrap|register|init|selftest|selfcheck|selfsrc|profile)
                set -- "--$_sub" "$@" ;;
        *)      ac_error "unknown command: $_sub (try: antcrate help)"; exit 2 ;;
    esac
    unset _sub
fi

NAME="" DOMAIN="" META="" REL="" EXPAND="" RESUME="" AUTO_YES="" GH_VIS="private" RESTORE_TS="" PROPOSE_DESC=""
ADDR_CODE="" RENAME_NEW="" LOGS_LINES="50" CMD_ARGS=() RELPATH="" REG_PATH="" DIAG_OUT=""
COMMIT_MSG="" COMMIT_MODE=""
TOOL_NAME="" TOOL_FORCE="" SCAN_PATH=""
EVENT_KIND="" EVENT_TTL="" EVENT_LABEL="" EVENT_AGENT=""
WATCH_ONCE="" WATCH_INTERVAL="" WATCH_NOCOLOR="" WATCH_DEPTH="" WATCH_FOLLOW=""
WATCH_SMOKE_KIND="" WATCH_SMOKE_REL=""
WATCH_WIN_TERMINAL=""
CLEANUP_IDS=()
BOOTSTRAP_WITH_REMOTE=""
HOOK_TEMPLATE="" HOOK_NAME="" HOOK_FORCE=""
HOOK_WITH_STASH="" HOOK_NO_TRACE=""
HOOK_BYPASS_REASON=""
MD_FORCE=""
SELFCHECK_QUIET=""
INTEL_SOURCE="" INTEL_QUIET="" INTEL_JSON="" INTEL_SHA=""
DUTY_TEXT="" DUTY_N="" DUTY_TYPE=""
FETCH_URL="" FETCH_NAME=""
CI_SNAPSHOT="" CI_SOURCE=""
HOOKSMOKE_ARGS=()
PROFILE_RAW=""
ENV_APPLY=""
HOOK_AUTO_DRY=""
QUARANTINE_PROJECT="" QUARANTINE_TS=""
RELOCATE_NO_WATCH=0
ACTION=""
while (( $# > 0 )); do
    case "$1" in
        --help|-h)           usage; exit 0 ;;
        --init)              ACTION="init"; shift ;;
        --status)            ACTION="status"; shift ;;
        --selfcheck)
            ACTION="selfcheck"
            if [[ "${2:-}" == "--quiet" ]]; then SELFCHECK_QUIET="--quiet"; shift 2; else shift; fi ;;
        --intel-pull)
            ACTION="intel-pull"; shift
            while [[ "${1:-}" == "--source" || "${1:-}" == "--quiet" ]]; do
                case "$1" in
                    --source) INTEL_SOURCE="${2:-}"; shift 2 ;;
                    --quiet)  INTEL_QUIET="--quiet"; shift ;;
                esac
            done ;;
        --intel-new)
            ACTION="intel-new"
            if [[ "${2:-}" == "--json" ]]; then INTEL_JSON="--json"; shift 2; else shift; fi ;;
        --intel-ack)
            ACTION="intel-ack"; NAME="${2:-}"; INTEL_SHA="${3:-}"
            if [[ $# -ge 3 ]]; then shift 3; elif [[ $# -ge 2 ]]; then shift 2; else shift; fi ;;
        --intel-status)      ACTION="intel-status"; shift ;;
        --list)              ACTION="list"; shift ;;
        --info)              ACTION="info"; NAME="${2:-}"; shift 2 ;;
        --start)             ACTION="start"; NAME="$2"; shift 2 ;;
        --register)
            ACTION="register"; NAME="${2:-}"; REG_PATH="${3:-}"
            if [[ $# -ge 3 && -n "${3:-}" && "${3:0:2}" != "--" ]]; then shift 3
            elif [[ $# -ge 2 ]]; then shift 2
            else shift; fi ;;
        --branch)            ACTION="branch"; NAME="$2"; shift 2 ;;
        --link)              ACTION="link"; NAME="$2"; shift 2 ;;
        --pp)                ACTION="pp"; NAME="$2"; shift 2 ;;
        --ingest)            ACTION="ingest"; NAME="$2"; shift 2 ;;
        --emit-activity)
            ACTION="emit-activity"; NAME="${2:-}"; EVENT_KIND="${3:-}"; RELPATH="${4:-}"
            if [[ $# -ge 4 ]]; then shift 4
            elif [[ $# -ge 3 ]]; then shift 3
            elif [[ $# -ge 2 ]]; then shift 2
            else shift; fi ;;
        --watch)
            ACTION="watch"; NAME=""
            if [[ -n "${2:-}" && "${2:0:2}" != "--" ]]; then NAME="$2"; shift 2; else shift; fi ;;
        --watch-smoke)
            ACTION="watch-smoke"; NAME="${2:-}"; shift 2
            WATCH_SMOKE_KIND=""; WATCH_SMOKE_REL=""
            if [[ $# -gt 0 && "${1:0:2}" != "--" ]]; then WATCH_SMOKE_KIND="$1"; shift; fi
            if [[ $# -gt 0 && "${1:0:2}" != "--" ]]; then WATCH_SMOKE_REL="$1"; shift; fi
            ;;
        --watch-window)
            ACTION="watch-window"; NAME="${2:-}"; shift 2
            WATCH_WIN_TERMINAL=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --terminal) WATCH_WIN_TERMINAL="$2"; shift 2 ;;
                    --*) break ;;
                    *) break ;;
                esac
            done ;;
        --cleanup)           ACTION="cleanup"; NAME="${2:-}"; shift 2 ;;
        --apply)             CLEANUP_IDS+=("$2"); shift 2 ;;
        --once)              WATCH_ONCE="1"; shift ;;
        --follow)            WATCH_FOLLOW="1"; shift ;;
        --interval-ms)       WATCH_INTERVAL="$2"; shift 2 ;;
        --no-color)          WATCH_NOCOLOR="1"; shift ;;
        --depth)             WATCH_DEPTH="$2"; shift 2 ;;
        --ttl-ms)            EVENT_TTL="$2"; shift 2 ;;
        --label)             EVENT_LABEL="$2"; shift 2 ;;
        --agent)             EVENT_AGENT="$2"; shift 2 ;;
        --commit)
            ACTION="commit"; NAME="${2:-}"; shift 2
            while (( $# > 0 )); do
                case "${1:-}" in
                    -m)            COMMIT_MSG="${2:-}"; shift 2 ;;
                    --all-tracked) COMMIT_MODE="all"; shift ;;
                    -y)            AUTO_YES="-y"; shift ;;
                    --)            shift; COMMIT_MODE="${COMMIT_MODE:-explicit}"; CMD_ARGS=( "$@" ); set -- ;;
                    *)             break ;;
                esac
            done ;;
        --resume)            ACTION="resume"; RESUME="$2"; shift 2 ;;
        --expand)            EXPAND="$2"; shift 2 ;;
        --gh-init)           ACTION="gh-init"; NAME="$2"; shift 2 ;;
        --gh-help)           ACTION="gh-help"; shift ;;
        --git-init)          ACTION="git-init"; NAME="$2"; shift 2 ;;
        --agent-init)        ACTION="agent-init"; NAME="$2"; shift 2 ;;
        --md-scaffold)
            ACTION="md-scaffold"; NAME="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            MD_FORCE=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --force) MD_FORCE="--force"; shift ;;
                    --*)     break ;;
                    *)       break ;;
                esac
            done ;;
        --profile)
            ACTION="profile"; NAME="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            PROFILE_RAW=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --raw) PROFILE_RAW="1"; shift ;;
                    --*)   break ;;
                    *)     break ;;
                esac
            done ;;
        --env-scan)
            ACTION="env-scan"; NAME="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            ENV_APPLY=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --apply) ENV_APPLY="--apply"; shift ;;
                    --*)     break ;;
                    *)       break ;;
                esac
            done ;;
        --hook-autoinstall)
            ACTION="hook-autoinstall"; NAME="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            HOOK_AUTO_DRY=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --dry-run) HOOK_AUTO_DRY="--dry-run"; shift ;;
                    --*)       break ;;
                    *)         break ;;
                esac
            done ;;
        --bootstrap)
            ACTION="bootstrap"; NAME="${2:-}"; shift 2
            while (( $# > 0 )); do
                case "${1:-}" in
                    -m)             COMMIT_MSG="${2:-}"; shift 2 ;;
                    --with-remote)  BOOTSTRAP_WITH_REMOTE=1; shift ;;
                    --public)       GH_VIS="public"; shift ;;
                    --private)      GH_VIS="private"; shift ;;
                    *)              break ;;
                esac
            done ;;
        --backup)            ACTION="backup"; NAME="$2"; shift 2 ;;
        --backups)           ACTION="backups"; NAME="$2"; shift 2 ;;
        --restore)           ACTION="restore"; NAME="$2"; shift 2 ;;
        --at)                RESTORE_TS="$2"; shift 2 ;;
        --propose)
            ACTION="propose"; NAME="${2:-}"
            if [[ $# -ge 3 && -n "${3:-}" && "${3:0:2}" != "--" ]]; then
                PROPOSE_DESC="$3"; shift 3
            elif [[ $# -ge 2 ]]; then
                shift 2
            else
                shift
            fi ;;
        --proposals)         ACTION="proposals"; shift ;;
        --policy)            ACTION="policy"; shift ;;
        --policy-init)       ACTION="policy_init"; shift ;;
        --duty)
            ACTION="duty"
            shift
            if [[ "${1:-}" == "--type" ]]; then
                DUTY_TYPE="${2:-}"; shift 2
            fi
            if [[ $# -ge 1 && -n "${1:-}" && "${1:0:2}" != "--" ]]; then
                DUTY_TEXT="$1"; shift
            fi ;;
        --duties)            ACTION="duties"; shift ;;
        --duty-done)         ACTION="duty-done"; DUTY_N="${2:-}"; shift 2 ;;
        --duties-clear)      ACTION="duties-clear"; shift ;;
        --duty-involvement)  ACTION="duty_involvement"; shift ;;
        --fetch)
            ACTION="fetch"
            shift
            if [[ $# -ge 1 && "${1:0:2}" != "--" ]]; then
                FETCH_URL="$1"; shift
            fi
            if [[ "${1:-}" == "--name" ]]; then
                FETCH_NAME="${2:-}"; shift 2
            fi ;;
        --addr)
            if [[ -z "$ACTION" ]]; then
                ACTION="addr"; NAME="${2:-}"; ADDR_CODE="${3:-}"
                if [[ $# -ge 3 ]]; then shift 3
                elif [[ $# -ge 2 ]]; then shift 2
                else shift; fi
            else
                # --addr used as modifier on --anchor / --in
                ADDR_CODE="${2:-}"; shift 2
            fi ;;
        --anchor)            ACTION="anchor"; NAME="${2:-}"; shift 2 ;;
        --in)
            ACTION="in"; NAME="${2:-}"; shift 2
            # consume --addr <code> if present, then -- and the rest
            if [[ "${1:-}" == "--addr" ]]; then ADDR_CODE="${2:-}"; shift 2; fi
            if [[ "${1:-}" == "--" ]]; then shift; fi
            CMD_ARGS=( "$@" ); set -- ;;
        --map)               ACTION="map"; NAME="${2:-}"; shift 2 ;;
        --rename)            ACTION="rename"; NAME="${2:-}"; RENAME_NEW="${3:-}"
                             if [[ $# -ge 3 ]]; then shift 3
                             elif [[ $# -ge 2 ]]; then shift 2
                             else shift; fi ;;
        --archive)           ACTION="archive"; NAME="${2:-}"; shift 2 ;;
        --unarchive)         ACTION="unarchive"; NAME="${2:-}"; shift 2 ;;
        --remove)            ACTION="remove"; NAME="${2:-}"; shift 2 ;;
        --relocate)
            ACTION="relocate"; NAME="${2:-}"
            if [[ $# -ge 2 ]]; then shift 2; else shift; fi
            while [[ "${1:-}" == "--no-watch" ]]; do RELOCATE_NO_WATCH=1; shift; done ;;
        --logs)
            ACTION="logs"; NAME="${2:-}"
            if [[ $# -ge 3 && "${3:-}" =~ ^[0-9]+$ ]]; then LOGS_LINES="$3"; shift 3
            elif [[ $# -ge 2 && "${2:-}" =~ ^[0-9]+$ ]]; then NAME=""; LOGS_LINES="$2"; shift 2
            elif [[ $# -ge 2 && -n "${2:-}" && "${2:0:2}" != "--" ]]; then shift 2
            else shift; fi ;;
        --diff)              ACTION="diff"; NAME="${2:-}"; shift 2 ;;
        --selfsrc)           ACTION="selfsrc"; shift ;;
        --tool-install)
            ACTION="tool-install"; shift
            if [[ "${1:-}" == "--force" ]]; then TOOL_FORCE="--force"; shift; fi
            TOOL_NAME="${1:-}"; if [[ -n "$TOOL_NAME" ]]; then shift || true; fi
            if [[ "${1:-}" == "--force" ]]; then TOOL_FORCE="--force"; shift; fi ;;
        --tool-list)         ACTION="tool-list"; shift ;;
        --tool-path)         ACTION="tool-path"; shift ;;
        --scan)
            ACTION="scan"; shift
            if [[ -n "${1:-}" && "${1:0:2}" != "--" ]]; then SCAN_PATH="$1"; shift; fi ;;
        --selfinstall)       ACTION="selfinstall"; shift ;;
        --install-from-source) ACTION="install-from-source"; shift ;;
        --selftest)
            ACTION="selftest"
            if [[ $# -ge 2 && -n "${2:-}" && "${2:0:2}" != "--" ]]; then NAME="$2"; shift 2
            else shift; fi ;;
        --selfedit)          ACTION="selfedit"; NAME="${2:-}"; shift 2 ;;
        --diagrams)          ACTION="diagrams"; NAME="${2:-}"; shift 2 ;;
        --registry-diagram)
            ACTION="registry-diagram"
            if [[ $# -ge 2 && -n "${2:-}" && "${2:0:2}" != "--" ]]; then DIAG_OUT="$2"; shift 2
            else shift; fi ;;
        --tree-diagram)
            ACTION="tree-diagram"; NAME="${2:-}"
            if [[ $# -ge 3 && -n "${3:-}" && "${3:0:2}" != "--" ]]; then DIAG_OUT="$3"; shift 3
            elif [[ $# -ge 2 ]]; then shift 2
            else shift; fi ;;
        --ci)
            ACTION="ci"; shift
            while [[ "${1:-}" == "--snapshot" || "${1:-}" == "--source" ]]; do
                case "$1" in
                    --snapshot) CI_SNAPSHOT="--snapshot"; shift ;;
                    --source)   CI_SOURCE="${2:-}"; shift 2 ;;
                esac
            done ;;
        --hook-smoke)
            ACTION="hook-smoke"; NAME="${2:-}"
            if [[ $# -ge 2 ]]; then shift 2; else shift; fi
            HOOKSMOKE_ARGS=()
            while [[ "${1:-}" == "--command" || "${1:-}" == "--file" || "${1:-}" == "--payload" || "${1:-}" == "--tool" ]]; do
                HOOKSMOKE_ARGS+=("$1" "${2:-}"); shift 2
            done ;;
        --hooks)             ACTION="hooks"; NAME="${2:-}"; shift 2 ;;
        --hook-log)
            ACTION="hook-log"; NAME="${2:-}"
            if [[ $# -ge 3 && "${3:-}" =~ ^[0-9]+$ ]]; then LOGS_LINES="$3"; shift 3
            elif [[ $# -ge 2 ]]; then shift 2
            else shift; fi ;;
        --hook-audit)
            ACTION="hook-audit"; NAME="${2:-}"
            if [[ $# -ge 3 && "${3:-}" =~ ^[0-9]+$ ]]; then LOGS_LINES="$3"; shift 3
            elif [[ $# -ge 2 ]]; then shift 2
            else shift; fi ;;
        --quarantine-list)
            ACTION="quarantine-list"; QUARANTINE_PROJECT="${2:-}"; shift
            [[ $# -gt 0 ]] && shift ;;
        --quarantine-restore)
            ACTION="quarantine-restore"; QUARANTINE_PROJECT="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            QUARANTINE_TS=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --at) QUARANTINE_TS="${2:-}"; shift 2 ;;
                    --*)  break ;;
                    *)    break ;;
                esac
            done ;;
        --ghosts)            ACTION="ghosts"; shift ;;
        --deregister)        ACTION="deregister"; NAME="${2:-}"; shift; [[ $# -gt 0 ]] && shift ;;
        --hook-install)
            ACTION="hook-install"; NAME="${2:-}"; HOOK_TEMPLATE="${3:-}"; shift
            [[ $# -gt 0 ]] && shift
            [[ $# -gt 0 ]] && shift
            HOOK_NAME=""
            HOOK_FORCE=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --force) HOOK_FORCE="--force"; shift ;;
                    --*)     break ;;
                    *)       HOOK_NAME="$1"; shift ;;
                esac
            done ;;
        --hook-remove)
            ACTION="hook-remove"; NAME="${2:-}"; HOOK_NAME="${3:-}"; shift
            [[ $# -gt 0 ]] && shift
            [[ $# -gt 0 ]] && shift
            HOOK_FORCE=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --force) HOOK_FORCE="--force"; shift ;;
                    --*)     break ;;
                    *)       shift ;;
                esac
            done ;;
        --hook-debug)
            ACTION="hook-debug"; NAME="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            HOOK_NAME=""
            HOOK_WITH_STASH=""
            HOOK_NO_TRACE=""
            # Optional positional hook name, then any combination of flags.
            while (( $# > 0 )); do
                case "${1:-}" in
                    --with-stash) HOOK_WITH_STASH="--with-stash"; shift ;;
                    --no-trace)   HOOK_NO_TRACE="--no-trace";     shift ;;
                    --*)          break ;;
                    *)            [[ -z "$HOOK_NAME" ]] && HOOK_NAME="$1"; shift ;;
                esac
            done ;;
        --hook-bypass)
            ACTION="hook-bypass"; NAME="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            HOOK_BYPASS_REASON=""
            while (( $# > 0 )); do
                case "${1:-}" in
                    --reason)
                        HOOK_BYPASS_REASON="${2:-}"
                        if [[ $# -ge 2 ]]; then shift 2; else shift; fi
                        ;;
                    --*)  break ;;
                    *)    shift ;;
                esac
            done ;;
        --hook-render)
            ACTION="hook-render"; HOOK_TEMPLATE="${2:-}"; shift
            [[ $# -gt 0 ]] && shift
            if [[ $# -gt 0 && "${1:0:2}" != "--" ]]; then NAME="$1"; shift; fi ;;
        --public)            GH_VIS="public"; shift ;;
        --private)           GH_VIS="private"; shift ;;
        --pipe-file)         ACTION="pipe-file"; NAME="$2"; shift 2 ;;
        --domain)            DOMAIN="$2"; shift 2 ;;
        --meta)              META="$2"; shift 2 ;;
        --rel)               REL="$2"; shift 2 ;;
        -y)                  AUTO_YES="-y"; shift ;;
        *) ac_error "unknown arg: $1"; usage; exit 2 ;;
    esac
done

# meta string → AC_META_VALUES array
META_VALUES=()
if [[ -n "$META" ]]; then
    if [[ "$META" =~ ^#.*#$ ]]; then META="${META#\#}"; META="${META%\#}"; fi
    IFS=',' read -r -a META_VALUES <<< "$META"
fi

case "$ACTION" in
    init)      cmd_init ;;
    status)    cmd_status ;;
    selfcheck) ac_selfcheck ${SELFCHECK_QUIET:+"$SELFCHECK_QUIET"} ;;
    intel-pull)
        INTEL_ARGS=()
        [[ -n "$INTEL_QUIET" ]]  && INTEL_ARGS+=(--quiet)
        [[ -n "$INTEL_SOURCE" ]] && INTEL_ARGS+=("$INTEL_SOURCE")
        ac_intel_pull "${INTEL_ARGS[@]}" ;;
    intel-new)    ac_intel_new ${INTEL_JSON:+"$INTEL_JSON"} ;;
    intel-ack)
        [[ -z "$NAME" || -z "$INTEL_SHA" ]] && { ac_error "--intel-ack requires <source_id> <sha256>"; exit 2; }
        ac_intel_ack "$NAME" "$INTEL_SHA" ;;
    intel-status) ac_intel_status ;;
    list)      cmd_list ;;
    info)
        [[ -z "$NAME" ]] && { ac_error "--info requires <project>"; exit 2; }
        ac_registry_info "$NAME"
        # read-only sibling of the pp panel (Plan 2): same dense read, no push
        INFO_PATH=$(ac_registry_get "$NAME" path 2>/dev/null) || INFO_PATH=""
        [[ -n "$INFO_PATH" ]] && ac_pp_panel "$NAME" "$INFO_PATH" ;;
    start)
        [[ -z "$DOMAIN" ]] && { ac_error "--start requires --domain"; exit 2; }
        ac_with_lock ac_action_start "$NAME" "$DOMAIN" "${META_VALUES[@]}"
        # auto-scaffold diagrams (idempotent) for any new project
        if ac_registry_has "$NAME"; then
            target_path=$(ac_registry_get "$NAME" path)
            ac_diagrams_scaffold "$target_path" "$NAME"
        fi
        ac_diagrams_auto_regen "$NAME"
        ac_lifecycle_treatment "$NAME" ;;
    register)
        [[ -z "$NAME" || -z "$REG_PATH" ]] && { ac_error "--register requires <name> <existing-path>"; exit 2; }
        ac_with_lock ac_action_register "$NAME" "$REG_PATH" "$DOMAIN"
        ac_diagrams_auto_regen "$NAME"
        ac_lifecycle_treatment "$NAME" ;;
    branch)
        [[ -z "$DOMAIN" ]] && { ac_error "--branch requires --domain"; exit 2; }
        ac_with_lock ac_action_branch "$NAME" "$DOMAIN" "${META_VALUES[@]}"
        ac_diagrams_auto_regen "$NAME" ;;
    link)
        [[ -z "$REL" ]] && { ac_error "--link requires --rel <other>"; exit 2; }
        ac_with_lock ac_action_link "$NAME" "_" "rel=$REL"
        ac_diagrams_auto_regen "$NAME" ;;
    pp)        cmd_pp "$NAME" "$AUTO_YES" ;;
    ingest)
        [[ -z "$NAME" ]] && { ac_error "--ingest requires <bundle-path>"; exit 2; }
        ac_with_lock ac_ingest "$NAME" ;;
    emit-activity)
        [[ -z "$NAME" || -z "$EVENT_KIND" || -z "$RELPATH" ]] && {
            ac_error "--emit-activity requires <project> <kind> <relpath>"; exit 2; }
        emit_args=()
        [[ -n "$EVENT_TTL"   ]] && emit_args+=(--ttl-ms "$EVENT_TTL")
        [[ -n "$EVENT_LABEL" ]] && emit_args+=(--label "$EVENT_LABEL")
        [[ -n "$EVENT_AGENT" ]] && emit_args+=(--agent "$EVENT_AGENT")
        ac_events_emit "$NAME" "$EVENT_KIND" "$RELPATH" "${emit_args[@]}" ;;
    watch)
        [[ -z "$NAME" && "$WATCH_FOLLOW" != "1" ]] && {
            ac_error "--watch requires <project> (or --follow)"; exit 2; }
        watch_args=()
        [[ "$WATCH_NOCOLOR" == "1" ]] && watch_args+=(--no-color)
        [[ -n "$WATCH_DEPTH"      ]] && watch_args+=(--depth "$WATCH_DEPTH")
        if [[ "$WATCH_ONCE" == "1" ]]; then
            WATCH_TARGET="$NAME"
            if [[ -z "$WATCH_TARGET" ]]; then
                WATCH_TARGET=$(ac_watch_hot_project) || {
                    ac_error "watch --follow: no project with active events"; exit 1; }
            fi
            ac_watch_render_once "$WATCH_TARGET" "${watch_args[@]}"
        else
            [[ -n "$WATCH_INTERVAL" ]] && watch_args+=(--interval-ms "$WATCH_INTERVAL")
            [[ "$WATCH_FOLLOW" == "1" ]] && watch_args+=(--follow)
            [[ -n "$NAME" ]] && watch_args=("$NAME" "${watch_args[@]}")
            ac_watch_loop "${watch_args[@]}"
        fi ;;
    watch-smoke)
        [[ -z "$NAME" ]] && { ac_error "--watch-smoke requires <project>"; exit 2; }
        smoke_args=()
        [[ -n "$WATCH_SMOKE_KIND" ]] && smoke_args+=("$WATCH_SMOKE_KIND")
        [[ -n "$WATCH_SMOKE_REL"  ]] && smoke_args+=("$WATCH_SMOKE_REL")
        [[ -n "$EVENT_TTL"        ]] && smoke_args+=(--ttl-ms "$EVENT_TTL")
        [[ -n "$WATCH_DEPTH"      ]] && smoke_args+=(--depth "$WATCH_DEPTH")
        [[ "$WATCH_NOCOLOR" == "1" ]] && smoke_args+=(--no-color)
        ac_watch_smoke "$NAME" "${smoke_args[@]}" ;;
    watch-window)
        [[ -z "$NAME" ]] && { ac_error "--watch-window requires <project>"; exit 2; }
        ww_args=( "$NAME" )
        [[ -n "$WATCH_WIN_TERMINAL" ]] && ww_args+=(--terminal "$WATCH_WIN_TERMINAL")
        ac_watch_window "${ww_args[@]}" ;;
    cleanup)
        [[ -z "$NAME" ]] && { ac_error "--cleanup requires <project>"; exit 2; }
        if (( ${#CLEANUP_IDS[@]} == 0 )); then
            ac_cleanup_classify "$NAME"
        else
            ac_with_lock ac_cleanup_apply "$NAME" "${CLEANUP_IDS[@]}"
            ac_diagrams_auto_regen "$NAME" >/dev/null 2>&1 || true
        fi ;;
    commit)
        if [[ -n "$AUTO_YES" ]]; then
            ANTCRATE_COMMIT_PREAPPROVED=1 ac_commit_run "$NAME" "$COMMIT_MSG" "$COMMIT_MODE" "${CMD_ARGS[@]}"
        else
            ac_commit_run "$NAME" "$COMMIT_MSG" "$COMMIT_MODE" "${CMD_ARGS[@]}"
        fi
        # auto-regen diagrams after commit (registry-only; project tree
        # may have changed too, so pass project)
        ac_diagrams_auto_regen "$NAME" >/dev/null 2>&1 || true ;;
    gh-init)
        [[ -z "$NAME" ]] && { ac_error "--gh-init requires <project>"; exit 2; }
        ac_with_lock ac_gh_init_repo "$NAME" "$GH_VIS" ;;
    gh-help)   ac_gh_login_hint ;;
    git-init)
        [[ -z "$NAME" ]] && { ac_error "--git-init requires <project>"; exit 2; }
        ac_with_lock ac_git_init "$NAME" ;;
    agent-init)
        [[ -z "$NAME" ]] && { ac_error "--agent-init requires <project>"; exit 2; }
        ac_with_lock ac_agent_init "$NAME" ;;
    md-scaffold)
        [[ -z "$NAME" ]] && { ac_error "--md-scaffold requires <project>"; exit 2; }
        md_args=( "$NAME" )
        [[ -n "$MD_FORCE" ]] && md_args+=( "$MD_FORCE" )
        ac_with_lock ac_md_scaffold "${md_args[@]}" ;;
    profile)
        [[ -z "$NAME" ]] && { ac_error "--profile requires <project>"; exit 2; }
        if [[ -n "$PROFILE_RAW" ]]; then
            ac_profile_raw "$NAME"
        else
            ac_profile "$NAME"
        fi ;;
    env-scan)
        [[ -z "$NAME" ]] && { ac_error "--env-scan requires <project>"; exit 2; }
        env_args=( "$NAME" )
        [[ -n "$ENV_APPLY" ]] && env_args+=( "$ENV_APPLY" )
        ac_with_lock ac_env_scan "${env_args[@]}" ;;
    hook-autoinstall)
        [[ -z "$NAME" ]] && { ac_error "--hook-autoinstall requires <project>"; exit 2; }
        ha_args=( "$NAME" )
        [[ -n "$HOOK_AUTO_DRY" ]] && ha_args+=( "$HOOK_AUTO_DRY" )
        ac_with_lock ac_hook_autoinstall "${ha_args[@]}" ;;
    bootstrap)
        [[ -z "$NAME" ]] && { ac_error "--bootstrap requires <project>"; exit 2; }
        ac_with_lock ac_bootstrap "$NAME" "$COMMIT_MSG" "$BOOTSTRAP_WITH_REMOTE" "$GH_VIS"
        ac_diagrams_auto_regen "$NAME" >/dev/null 2>&1 || true ;;
    backup)
        [[ -z "$NAME" ]] && { ac_error "--backup requires <project>"; exit 2; }
        ac_registry_has "$NAME" || { ac_error "unknown project: $NAME"; exit 1; }
        p=$(ac_registry_get "$NAME" path)
        ac_backup_run "$NAME" "$p" ;;
    backups)
        [[ -z "$NAME" ]] && { ac_error "--backups requires <project>"; exit 2; }
        ac_backup_list "$NAME" ;;
    restore)
        [[ -z "$NAME" ]] && { ac_error "--restore requires <project>"; exit 2; }
        if [[ -n "$RESTORE_TS" ]]; then
            tarball="$ANTCRATE_HOME/backups/$NAME/${NAME}-${RESTORE_TS}.tar.gz"
            ac_backup_restore "$NAME" "$tarball"
        else
            ac_backup_restore "$NAME"
        fi
        ac_diagrams_auto_regen "$NAME" ;;
    resume)
        [[ -z "$EXPAND" ]] && { ac_error "--resume requires --expand <child>"; exit 2; }
        cmd_resume_expand "$RESUME" "$EXPAND"
        ac_diagrams_auto_regen "$RESUME" ;;
    propose)
        [[ -z "$NAME" ]] && { ac_error "--propose requires <name>"; exit 2; }
        [[ -z "$PROPOSE_DESC" ]] && { ac_error "--propose requires <description>"; exit 2; }
        ac_propose_pattern "$NAME" "$PROPOSE_DESC" ;;
    proposals) ac_propose_list ;;
    policy)      ac_policy_show ;;
    policy_init) ac_policy_seed ;;
    duty)
        [[ -z "$DUTY_TEXT" ]] && { ac_error "--duty requires \"<text>\""; exit 2; }
        if [[ -n "$DUTY_TYPE" ]]; then
            ac_duty_add --type "$DUTY_TYPE" "$DUTY_TEXT"
        else
            ac_duty_add "$DUTY_TEXT"
        fi ;;
    duties)    ac_duty_list ;;
    duty-done) ac_duty_done "$DUTY_N" ;;
    duties-clear) ac_duty_done_all ;;
    duty_involvement) ac_duty_involvement ;;
    fetch)
        if [[ -n "$FETCH_NAME" ]]; then
            ac_fetch "$FETCH_URL" --name "$FETCH_NAME"
        else
            ac_fetch "$FETCH_URL"
        fi ;;
    addr)
        [[ -z "$NAME" || -z "$ADDR_CODE" ]] && { ac_error "--addr requires <project> <code>"; exit 2; }
        ac_registry_has "$NAME" || { ac_error "unknown project: $NAME"; exit 1; }
        root=$(ac_registry_get "$NAME" path)
        ac_addr_resolve "$root" "$ADDR_CODE" ;;
    anchor)
        [[ -z "$NAME" ]] && { ac_error "--anchor requires <project>"; exit 2; }
        ac_anchor_export "$NAME" "$ADDR_CODE" ;;
    in)
        [[ -z "$NAME" ]] && { ac_error "--in requires <project>"; exit 2; }
        (( ${#CMD_ARGS[@]} )) || { ac_error "--in requires a command after --"; exit 2; }
        ac_anchor_run "$NAME" "$ADDR_CODE" -- "${CMD_ARGS[@]}" ;;
    map)
        [[ -z "$NAME" ]] && { ac_error "--map requires <project>"; exit 2; }
        ac_devops_map "$NAME" ;;
    rename)
        [[ -z "$NAME" || -z "$RENAME_NEW" ]] && { ac_error "--rename requires <project> <new-name>"; exit 2; }
        ac_with_lock ac_devops_rename "$NAME" "$RENAME_NEW"
        ac_diagrams_auto_regen "$RENAME_NEW"
        ac_lifecycle_treatment "$RENAME_NEW" ;;
    archive)
        [[ -z "$NAME" ]] && { ac_error "--archive requires <project>"; exit 2; }
        ac_with_lock ac_devops_archive "$NAME"
        ac_diagrams_auto_regen "" ;;
    unarchive)
        [[ -z "$NAME" ]] && { ac_error "--unarchive requires <project>"; exit 2; }
        ac_with_lock ac_devops_unarchive "$NAME"
        ac_diagrams_auto_regen "$NAME" ;;
    remove)
        [[ -z "$NAME" ]] && { ac_error "--remove requires <project>"; exit 2; }
        ac_with_lock ac_devops_remove "$NAME"
        ac_diagrams_auto_regen "" ;;
    relocate)
        [[ -z "$NAME" ]] && { ac_error "--relocate requires <project>"; exit 2; }
        relocate_args=( "$NAME" )
        (( RELOCATE_NO_WATCH == 1 )) && relocate_args+=( --no-watch )
        ac_with_lock ac_relocate "${relocate_args[@]}" ;;
    logs)      ac_devops_logs "$NAME" "$LOGS_LINES" ;;
    diff)      ac_devops_diff "$NAME" ;;
    selfsrc)   ac_devops_selfsrc ;;
    tool-install)
        [[ -z "$TOOL_NAME" ]] && { ac_error "--tool-install requires <tool> (see --tool-list)"; exit 2; }
        ac_tool_install "$TOOL_NAME" "$TOOL_FORCE" ;;
    tool-list)  ac_tool_list ;;
    tool-path)  ac_tool_path ;;
    scan)       ac_scan_run "${SCAN_PATH:-$PWD}" ;;
    selfinstall) ac_devops_selfinstall ;;
    install-from-source) ac_devops_install_from_source ;;
    selftest)  ac_devops_selftest "$NAME" ;;
    selfedit)
        [[ -z "$NAME" ]] && { ac_error "--selfedit requires <relpath>"; exit 2; }
        ac_devops_selfedit "$NAME" ;;
    diagrams)
        [[ -z "$NAME" ]] && { ac_error "--diagrams requires <project>"; exit 2; }
        ac_registry_has "$NAME" || { ac_error "unknown project: $NAME"; exit 1; }
        ac_diagrams_render "$NAME" ;;
    registry-diagram)
        ac_diagrams_registry_emit "$DIAG_OUT" ;;
    tree-diagram)
        [[ -z "$NAME" ]] && { ac_error "--tree-diagram requires <project>"; exit 2; }
        ac_registry_has "$NAME" || { ac_error "unknown project: $NAME"; exit 1; }
        ac_diagrams_tree_emit "$NAME" "$DIAG_OUT" ;;
    ci)
        CI_ARGS=()
        [[ -n "$CI_SNAPSHOT" ]] && CI_ARGS+=(--snapshot)
        [[ -n "$CI_SOURCE" ]]   && CI_ARGS+=(--source "$CI_SOURCE")
        ac_devops_ci "${CI_ARGS[@]+"${CI_ARGS[@]}"}" ;;
    hook-smoke)
        [[ -z "$NAME" ]] && { ac_error "--hook-smoke requires <hook-script>"; exit 2; }
        ac_hook_smoke "$NAME" "${HOOKSMOKE_ARGS[@]+"${HOOKSMOKE_ARGS[@]}"}" ;;
    hooks)
        [[ -z "$NAME" ]] && { ac_error "--hooks requires <project>"; exit 2; }
        ac_hooks_list "$NAME" ;;
    hook-log)
        [[ -z "$NAME" ]] && { ac_error "--hook-log requires <project>"; exit 2; }
        ac_hooks_log "$NAME" "$LOGS_LINES" ;;
    hook-audit)
        [[ -z "$NAME" ]] && { ac_error "--hook-audit requires <project>"; exit 2; }
        ac_hook_audit "$NAME" "$LOGS_LINES" ;;
    hook-install)
        [[ -z "$NAME"           ]] && { ac_error "--hook-install requires <project> <template>"; exit 2; }
        [[ -z "$HOOK_TEMPLATE"  ]] && { ac_error "--hook-install requires a template name"; exit 2; }
        # Pass positionals + flags to ac_hook_install; empty hook-name and
        # empty force-flag are dropped by the function's parser.
        args=( "$NAME" "$HOOK_TEMPLATE" )
        [[ -n "$HOOK_NAME"  ]] && args+=( "$HOOK_NAME" )
        [[ -n "$HOOK_FORCE" ]] && args+=( "$HOOK_FORCE" )
        ac_with_lock ac_hook_install "${args[@]}" ;;
    hook-debug)
        [[ -z "$NAME" ]] && { ac_error "--hook-debug requires <project>"; exit 2; }
        hd_args=( "$NAME" )
        [[ -n "$HOOK_NAME"       ]] && hd_args+=( "$HOOK_NAME" )
        [[ -n "$HOOK_WITH_STASH" ]] && hd_args+=( "$HOOK_WITH_STASH" )
        [[ -n "$HOOK_NO_TRACE"   ]] && hd_args+=( "$HOOK_NO_TRACE" )
        ac_with_lock ac_hook_debug "${hd_args[@]}" ;;
    hook-bypass)
        [[ -z "$NAME"               ]] && { ac_error "--hook-bypass requires <project>"; exit 2; }
        [[ -z "$HOOK_BYPASS_REASON" ]] && { ac_error "--hook-bypass requires --reason \"<text>\""; exit 2; }
        ac_with_lock ac_hook_bypass "$NAME" --reason "$HOOK_BYPASS_REASON" ;;
    hook-render)
        [[ -z "$HOOK_TEMPLATE" ]] && { ac_error "--hook-render requires <template>"; exit 2; }
        ac_hook_render "$HOOK_TEMPLATE" "$NAME" ;;
    hook-remove)
        [[ -z "$NAME"      ]] && { ac_error "--hook-remove requires <project> <hook>"; exit 2; }
        [[ -z "$HOOK_NAME" ]] && { ac_error "--hook-remove requires a hook name"; exit 2; }
        args=( "$NAME" "$HOOK_NAME" )
        [[ -n "$HOOK_FORCE" ]] && args+=( "$HOOK_FORCE" )
        ac_with_lock ac_hook_remove "${args[@]}" ;;
    quarantine-list)
        [[ -z "$QUARANTINE_PROJECT" ]] && { ac_error "--quarantine-list requires <project>"; exit 2; }
        ac_quarantine_list "$QUARANTINE_PROJECT" ;;
    quarantine-restore)
        [[ -z "$QUARANTINE_PROJECT" ]] && { ac_error "--quarantine-restore requires <project>"; exit 2; }
        [[ -z "$QUARANTINE_TS"      ]] && { ac_error "--quarantine-restore requires --at <ts>"; exit 2; }
        ac_quarantine_restore "$QUARANTINE_PROJECT" "$QUARANTINE_TS" ;;
    ghosts)     ac_hygiene_ghosts ;;
    deregister)
        [[ -z "$NAME" ]] && { ac_error "--deregister requires <project>"; exit 2; }
        ac_hygiene_deregister "$NAME" ;;
    pipe-file) cmd_pipe_file "$NAME" ;;
    "")        usage; exit 2 ;;
esac
